# MARDUK public starter configuration contract.
#
# Copy this file to a private operational repo as marduk.env, replace every
# placeholder, and keep real topology values out of public repos.
# Do not put secret values in this file.

MARDUK_CLUSTER_NAME=marduk-example

# Proxmox substrate.
PROXMOX_ENDPOINT=https://proxmox.example.invalid:8006/api2/json
PROXMOX_NODE=replace-with-proxmox-node
PROXMOX_STORAGE=replace-with-storage
PROXMOX_BRIDGE=replace-with-bridge
MARDUK_VLAN_ID=replace-with-vlan-id
MARDUK_GATEWAY=192.0.2.1
MARDUK_DNS=192.0.2.53

# Three Talos nodes. Use your own VM IDs and RFC1918 lab IPs.
MARDUK_NODE1_NAME=marduk-01
MARDUK_NODE1_IP=192.0.2.11
MARDUK_NODE1_VMID=replace-with-vm-id-1
MARDUK_NODE2_NAME=marduk-02
MARDUK_NODE2_IP=192.0.2.12
MARDUK_NODE2_VMID=replace-with-vm-id-2
MARDUK_NODE3_NAME=marduk-03
MARDUK_NODE3_IP=192.0.2.13
MARDUK_NODE3_VMID=replace-with-vm-id-3
MARDUK_KUBE_VIP=192.0.2.10

# GitOps, registry, public edge, backups, and observability.
GITOPS_REPO_URL=git@example.invalid:owner/private-marduk-ops.git
REGISTRY_HOSTNAME=registry.example.invalid
PUBLIC_DOMAIN=example.invalid
BACKUP_TARGET_HOST=backup.example.invalid
OBSERVABILITY_ENDPOINT=https://grafana.example.invalid
